{
  "name": "@pwa-apart/client",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "mobile:build": "npm run mobile:build:live",
    "mobile:build:live": "MOBILE_BUILD=1 tsc -b && MOBILE_BUILD=1 vite build --mode mobile.live",
    "mobile:build:local": "MOBILE_BUILD=1 tsc -b && MOBILE_BUILD=1 vite build --mode mobile.local",
    "mobile:add:android": "cap add android",
    "mobile:sync": "npm run mobile:sync:live",
    "mobile:sync:live": "npm run mobile:build:live && cap sync android",
    "mobile:sync:local": "npm run mobile:build:local && cap sync android",
    "mobile:open:android": "cap open android",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.6",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.1",
    "@capacitor/cli": "^7.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-pwa": "^0.20.5"
  }
}
