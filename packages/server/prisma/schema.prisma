generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  SECRETARY
  JOINT_SECRETARY
  TREASURER
  OWNER
  TENANT
  SERVICE_STAFF
}

enum FlatType {
  ONE_BHK
  TWO_BHK
  THREE_BHK
  FOUR_BHK
  STUDIO
  PENTHOUSE
  SHOP
  OTHER
}

enum BillStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PHONEPE
  CASH
  CHEQUE
  BANK_TRANSFER
  UPI_OTHER
}

enum PaymentGateway {
  PHONEPE
}

enum PaymentGatewayEnv {
  UAT
  PRODUCTION
}

enum PremiumSubscriptionStatus {
  PENDING
  ACTIVE
  HALTED
  CANCELLED
  COMPLETED
  FAILED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VisitorStatus {
  ACTIVE
  LEFT
}

enum DeliveryType {
  COURIER
  FOOD
  GROCERY
  MEDICINE
  PARCEL
  OTHER
}

enum ExpenseCategory {
  MAINTENANCE
  REPAIR
  SALARY
  ELECTRICITY
  WATER
  SECURITY
  CLEANING
  GARDENING
  LIFT
  SINKING_FUND
  INSURANCE
  LEGAL
  EVENTS
  OTHER
}

enum EventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum AssetType {
  LIFT
  WATER_TANK
  TOILET
  AUDITORIUM
  SEPTIC_TANK
  GARDEN
  GENERATOR
  PUMP
  FIRE_SAFETY
  OTHER
}

enum ServiceFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum ServiceJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  POSTPONED
  RESCHEDULED
}

enum ServiceJobPriority {
  LOW
  MEDIUM
  HIGH
}

// ─── SOCIETY / APARTMENT COMPLEX (TENANT) ───────────────
// Each society is a separate tenant in the multi-tenant system.
// When a new apartment registers, a new Society + Admin user is created.

model Society {
  id              String   @id @default(uuid())
  name            String
  address         String
  city            String
  state           String
  pincode         String
  registrationNo  String?  @unique
  totalBlocks     Int      @default(1)
  totalFlats      Int      @default(0)
  logo            String?
  isActive        Boolean  @default(true)
  isPremium       Boolean  @default(false)
  hadPremiumSubscription Boolean @default(false)
  premiumArchivedAt DateTime?
  premiumArchiveReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  blocks             Block[]
  users              User[]
  userMemberships    UserSocietyMembership[]
  complaints         Complaint[]
  visitors           Visitor[]
  deliveries         Delivery[]
  pushDevices        PushNotificationDevice[]
  announcementBroadcasts AnnouncementBroadcast[]
  events             SocietyEvent[]
  memberRemovalAudits MemberRemovalAudit[]
  roleMenuConfigs    SocietyRoleMenuConfig[]
  expenses           Expense[]
  bylaws             AssociationBylaw[]
  maintenanceConfig  MaintenanceConfig[]
  paymentConfigs     PaymentGatewayConfig[]
  premiumSubscriptions PremiumSubscription[]
  assets             Asset[]
  serviceJobs        ServiceJob[]
  serviceHistories   ServiceHistory[]

  @@map("societies")
}

// ─── BLOCK / WING ───────────────────────────────────────

model Block {
  id        String   @id @default(uuid())
  name      String   // e.g., "A Wing", "Block 1"
  floors    Int      @default(1)
  societyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  flats     Flat[]
  assets    Asset[]

  @@index([societyId])
  @@index([societyId, name])
  @@map("blocks")
}

// ─── FLAT ───────────────────────────────────────────────

model Flat {
  id          String   @id @default(uuid())
  flatNumber  String
  floor       Int
  type        FlatType @default(TWO_BHK)
  areaSqFt    Float?
  blockId     String
  isOccupied  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  owner       Owner?
  tenant      Tenant?
  bills       MaintenanceBill[]
  complaints  Complaint[]
  visitors    Visitor[]
  deliveries  Delivery[]

  @@unique([flatNumber, blockId])
  @@index([blockId])
  @@index([blockId, isOccupied])
  @@map("flats")
}

// ─── OWNER ──────────────────────────────────────────────

model Owner {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String
  altPhone    String?
  aadharNo    String?
  panNo       String?
  flatId      String   @unique
  moveInDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flat        Flat     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?

  @@index([userId])
  @@index([email])
  @@map("owners")
}

// ─── TENANT ─────────────────────────────────────────────

model Tenant {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String
  altPhone    String?
  aadharNo    String?
  flatId      String    @unique
  leaseStart  DateTime
  leaseEnd    DateTime?
  rentAmount  Float?
  deposit     Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  flat        Flat      @relation(fields: [flatId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?

  @@index([userId])
  @@index([email])
  @@map("tenants")
}

// ─── USER (AUTH) ────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  name                 String
  phone                String?
  role                 Role      @default(OWNER)
  specialization       String?
  societyId            String?
  activeSocietyId      String?
  isActive             Boolean   @default(true)
  mustChangePassword   Boolean   @default(false)
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  society      Society?  @relation(fields: [societyId], references: [id])
  owners       Owner[]
  tenants      Tenant[]
  societyMemberships UserSocietyMembership[]
  complaints   Complaint[] @relation("ComplaintCreator")
  assignedComplaints Complaint[] @relation("ComplaintAssignee")
  capturedVisitors Visitor[] @relation("VisitorCapturedBy")
  capturedDeliveries Delivery[] @relation("DeliveryCapturedBy")
  pushDevices       PushNotificationDevice[]
  announcementBroadcasts AnnouncementBroadcast[] @relation("AnnouncementBroadcastCreator")
  announcementReads AnnouncementReadState[]
  createdEvents     SocietyEvent[] @relation("SocietyEventCreator")
  assignedServiceJobs ServiceJob[]

  @@index([societyId])
  @@index([activeSocietyId])
  @@map("users")
}

model PushNotificationDevice {
  id               String    @id @default(uuid())
  userId           String
  societyId        String
  token            String
  platform         String
  lastRegisteredAt DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  society          Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([userId, societyId, token])
  @@index([userId])
  @@index([societyId])
  @@index([token])
  @@map("push_notification_devices")
}

model AnnouncementBroadcast {
  id           String   @id @default(uuid())
  societyId    String
  createdById  String
  title        String
  message      String
  images       String?
  path         String?
  targetRoles  String?
  sentCount    Int      @default(0)
  isPinned     Boolean  @default(false)
  pinnedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  society      Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("AnnouncementBroadcastCreator", fields: [createdById], references: [id], onDelete: Cascade)
  readStates   AnnouncementReadState[]

  @@index([societyId])
  @@index([createdById])
  @@index([societyId, isPinned, createdAt])
  @@map("announcement_broadcasts")
}

model AnnouncementReadState {
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement   AnnouncementBroadcast @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@index([userId])
  @@map("announcement_read_states")
}

model SocietyEvent {
  id              String                @id @default(uuid())
  societyId       String
  createdById     String
  title           String
  description     String
  place           String
  startAt         DateTime
  endAt           DateTime?
  status          EventStatus           @default(SCHEDULED)
  imageUrls       String?
  reminderMinutes String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  society         Society               @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdBy       User                  @relation("SocietyEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reminderLogs    SocietyEventReminder[]

  @@index([societyId])
  @@index([createdById])
  @@index([status])
  @@index([startAt])
  @@index([societyId, startAt])
  @@map("society_events")
}

model SocietyEventReminder {
  id                    String      @id @default(uuid())
  eventId               String
  reminderMinutesBefore Int
  sentCount             Int         @default(0)
  failedCount           Int         @default(0)
  sentAt                DateTime    @default(now())

  event                 SocietyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, reminderMinutesBefore])
  @@index([eventId])
  @@map("society_event_reminders")
}

model UserSocietyMembership {
  id         String   @id @default(uuid())
  userId     String
  societyId  String
  role       Role
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  society    Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([userId, societyId])
  @@index([societyId])
  @@map("user_society_memberships")
}

model MemberRemovalAudit {
  id              String   @id @default(uuid())
  societyId       String
  targetUserId    String?
  targetRole      String
  deletedByUserId String
  deletedByRole   String
  reason          String
  source          String
  ownerId         String?
  tenantId        String?
  flatId          String?
  snapshot        String?
  createdAt       DateTime @default(now())

  society         Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@index([targetUserId])
  @@index([deletedByUserId])
  @@map("member_removal_audits")
}

model SocietyRoleMenuConfig {
  id              String   @id @default(uuid())
  societyId       String
  role            Role
  visibleMenuIds  String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  society         Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, role])
  @@index([societyId])
  @@map("society_role_menu_configs")
}

// ─── MAINTENANCE CONFIG ─────────────────────────────────

model MaintenanceConfig {
  id              String   @id @default(uuid())
  societyId       String
  flatType        FlatType
  baseAmount      Float
  waterCharge     Float    @default(0)
  parkingCharge   Float    @default(0)
  sinkingFund     Float    @default(0)
  repairFund      Float    @default(0)
  otherCharges    Float    @default(0)
  lateFeePerDay   Float    @default(0)
  dueDay          Int      @default(10)
  effectiveFrom   DateTime @default(now())
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  society         Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, flatType, isActive])
  @@index([societyId])
  @@map("maintenance_configs")
}

// ─── MAINTENANCE BILL ───────────────────────────────────

model MaintenanceBill {
  id            String      @id @default(uuid())
  flatId        String
  month         Int
  year          Int
  baseAmount    Float
  waterCharge   Float       @default(0)
  parkingCharge Float       @default(0)
  sinkingFund   Float       @default(0)
  repairFund    Float       @default(0)
  otherCharges  Float       @default(0)
  lateFee       Float       @default(0)
  totalAmount   Float
  paidAmount    Float       @default(0)
  dueDate       DateTime
  status        BillStatus  @default(PENDING)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  flat          Flat        @relation(fields: [flatId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@unique([flatId, month, year])
  @@index([flatId])
  @@index([flatId, status])
  @@index([year, month])
  @@index([status])
  @@index([dueDate])
  @@map("maintenance_bills")
}

// ─── PAYMENT ────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  billId            String
  amount            Float
  method            PaymentMethod @default(PHONEPE)
  status            PaymentStatus @default(INITIATED)
  transactionId     String?       @unique
  merchantTransId   String?       @unique
  phonepeResponse   String?
  receiptNo         String?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  bill              MaintenanceBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([status, paidAt])
  @@index([notes])
  @@map("payments")
}

// ─── PLATFORM PREMIUM SUBSCRIPTIONS ───────────────────

model PremiumSubscription {
  id                    String                    @id @default(uuid())
  societyId             String
  status                PremiumSubscriptionStatus @default(PENDING)
  providerStatus        String?
  lockedFlatCount       Int
  includedFlatCount     Int
  amountPerFlatPaise    Int
  amountPaise           Int
  currency              String                    @default("INR")
  razorpayPlanId        String?
  razorpaySubscriptionId String?                  @unique
  usesPerFlatQuantity   Boolean                   @default(false)
  scheduledFlatCount    Int?
  scheduledAmountPaise  Int?
  scheduledChangeAt     DateTime?
  scheduledPlanId       String?
  overdueStartedAt      DateTime?
  warningNoticeSentAt   DateTime?
  loginBlockedNoticeSentAt DateTime?
  finalNoticeSentAt     DateTime?
  startDate             DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  nextBillingAt         DateTime?
  cancelledAt           DateTime?
  expiresAt             DateTime?
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  society               Society                   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  payments              PremiumSubscriptionPayment[]

  @@index([societyId])
  @@index([societyId, status])
  @@map("premium_subscriptions")
}

model PremiumSubscriptionPayment {
  id                    String               @id @default(uuid())
  premiumSubscriptionId String
  status                PaymentStatus        @default(INITIATED)
  amountPaise           Int
  currency              String               @default("INR")
  razorpayPaymentId     String?              @unique
  razorpayInvoiceId     String?
  razorpayOrderId       String?
  failureReason         String?
  rawPayload            String?
  paidAt                DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  premiumSubscription   PremiumSubscription  @relation(fields: [premiumSubscriptionId], references: [id], onDelete: Cascade)

  @@index([premiumSubscriptionId])
  @@index([razorpayInvoiceId])
  @@map("premium_subscription_payments")
}

// ─── COMPLAINT ──────────────────────────────────────────

model Complaint {
  id           String            @id @default(uuid())
  societyId    String
  flatId       String?
  createdById  String
  assignedToId String?
  title        String
  description  String
  category     String
  priority     ComplaintPriority @default(MEDIUM)
  status       ComplaintStatus   @default(OPEN)
  images       String            @default("[]")
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  society      Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  flat         Flat?    @relation(fields: [flatId], references: [id])
  createdBy    User     @relation("ComplaintCreator", fields: [createdById], references: [id])
  assignedTo   User?    @relation("ComplaintAssignee", fields: [assignedToId], references: [id])
  comments     ComplaintComment[]

  @@index([societyId])
  @@index([createdById])
  @@index([societyId, status])
  @@index([createdById, status])
  @@map("complaints")
}

model ComplaintComment {
  id          String   @id @default(uuid())
  complaintId String
  authorName  String
  content     String
  createdAt   DateTime @default(now())

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_comments")
}

// ─── EXPENSE ────────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  societyId   String
  category    ExpenseCategory
  amount      Float
  description String
  vendor      String?
  receiptUrl  String?
  expenseDate DateTime
  accountingMonth Int
  accountingYear  Int
  approvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  society     Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@index([societyId, expenseDate])
  @@index([societyId, accountingYear, accountingMonth])
  @@index([societyId, category])
  @@map("expenses")
}

model Visitor {
  id               String        @id @default(uuid())
  societyId        String
  flatId           String
  capturedByUserId String
  visitorName      String
  mobile           String
  vehicleNumber    String?
  purpose          String
  notes            String?
  photoUrl         String?
  status           VisitorStatus @default(ACTIVE)
  checkedInAt      DateTime      @default(now())
  checkedOutAt     DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  society          Society       @relation(fields: [societyId], references: [id], onDelete: Cascade)
  flat             Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  capturedBy       User          @relation("VisitorCapturedBy", fields: [capturedByUserId], references: [id])

  @@index([societyId])
  @@index([flatId])
  @@index([capturedByUserId])
  @@index([societyId, status])
  @@index([checkedInAt])
  @@map("visitors")
}

model Delivery {
  id                 String       @id @default(uuid())
  societyId          String
  flatId             String
  capturedByUserId   String
  deliveryType       DeliveryType
  deliveryPersonName String
  mobile             String?
  companyName        String?
  vehicleNumber      String?
  notes              String?
  photoUrl           String?
  deliveredAt        DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  society            Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  flat               Flat         @relation(fields: [flatId], references: [id], onDelete: Cascade)
  capturedBy         User         @relation("DeliveryCapturedBy", fields: [capturedByUserId], references: [id])

  @@index([societyId])
  @@index([flatId])
  @@index([capturedByUserId])
  @@index([societyId, deliveryType])
  @@index([deliveredAt])
  @@map("deliveries")
}

// ─── ASSOCIATION BYLAWS ─────────────────────────────────

model AssociationBylaw {
  id            String   @id @default(uuid())
  societyId     String
  title         String
  content       String
  category      String
  penaltyAmount Float?
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  society       Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@map("association_bylaws")
}

// ─── PAYMENT GATEWAY CONFIG ─────────────────────────────

model PaymentGatewayConfig {
  id            String            @id @default(uuid())
  societyId     String
  gateway       PaymentGateway    @default(PHONEPE)
  merchantId    String
  clientId      String?
  clientSecret  String?
  clientVersion Int               @default(1)
  saltKey       String
  saltIndex     Int               @default(1)
  environment   PaymentGatewayEnv @default(UAT)
  baseUrl       String            @default("https://api-preprod.phonepe.com/apis/pg-sandbox")
  redirectUrl   String            @default("http://localhost:5173/billing?payment=done")
  callbackUrl   String            @default("http://localhost:4000/api/payments/phonepe/callback")
  isActive      Boolean           @default(true)
  lastTestedAt  DateTime?
  lastTestOk    Boolean?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  society       Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, gateway])
  @@index([societyId])
  @@map("payment_gateway_configs")
}

// ─── ASSET MANAGEMENT ───────────────────────────────────

model Asset {
  id                       String            @id @default(uuid())
  societyId                String
  name                     String
  type                     AssetType
  location                 String?
  blockId                  String?
  description              String?
  installationDate         DateTime?
  vendor                   String?
  serviceContact           String?
  periodicServiceRequired  Boolean           @default(false)
  serviceFrequency         ServiceFrequency?
  serviceIntervalDays      Int?
  lastServiceDate          DateTime?
  nextServiceDate          DateTime?
  serviceVendor            String?
  serviceCost              Float?
  serviceNotes             String?
  images                   String            @default("[]")
  isActive                 Boolean           @default(true)
  lastReminderSentAt       DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  society        Society         @relation(fields: [societyId], references: [id], onDelete: Cascade)
  block          Block?          @relation(fields: [blockId], references: [id])
  serviceJobs    ServiceJob[]
  serviceHistory ServiceHistory[]

  @@index([societyId])
  @@index([societyId, type])
  @@index([societyId, blockId])
  @@index([societyId, nextServiceDate])
  @@index([societyId, isActive])
  @@map("assets")
}

model ServiceJob {
  id                String             @id @default(uuid())
  assetId           String
  societyId         String
  jobType           String             @default("Periodic Service")
  scheduledDate     DateTime
  assignedTo        String?
  assignedToUserId  String?
  priority          ServiceJobPriority @default(MEDIUM)
  status            ServiceJobStatus   @default(PENDING)
  remarks           String?
  completedDate     DateTime?
  images            String             @default("[]")
  invoiceUrl        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  asset        Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  society      Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  assignedUser User?   @relation(fields: [assignedToUserId], references: [id])
  history      ServiceHistory[]

  @@index([societyId])
  @@index([assetId])
  @@index([societyId, status])
  @@index([societyId, scheduledDate])
  @@map("service_jobs")
}

model ServiceHistory {
  id          String   @id @default(uuid())
  assetId     String
  societyId   String
  serviceDate DateTime
  vendor      String?
  notes       String?
  cost        Float?
  images      String   @default("[]")
  invoiceUrl  String?
  jobId       String?
  createdAt   DateTime @default(now())

  asset   Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  society Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  job     ServiceJob? @relation(fields: [jobId], references: [id])

  @@index([assetId])
  @@index([assetId, serviceDate])
  @@map("service_history")
}
