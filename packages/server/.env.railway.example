# === Railway Production Environment ===
# Railway auto-injects PORT and DATABASE_URL (when Postgres service is linked)

# Database (auto-injected by Railway Postgres — only set manually if using external DB)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET="generate-a-strong-secret-here"
JWT_REFRESH_SECRET="generate-another-strong-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
NODE_ENV="production"
# PORT is set automatically by Railway — do not override

# PhonePe (configured via Admin UI Settings page, these are fallback only)
PHONEPE_MERCHANT_ID=""
PHONEPE_SALT_KEY=""
PHONEPE_SALT_INDEX="1"
PHONEPE_ENV="PRODUCTION"
PHONEPE_BASE_URL="https://api.phonepe.com/apis/hermes"
PHONEPE_REDIRECT_URL="https://your-frontend.vercel.app/billing?payment=done"
PHONEPE_CALLBACK_URL="https://your-server.up.railway.app/api/payments/phonepe/callback"

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
CLIENT_URL="https://your-frontend.vercel.app"

# Email (SMTP)
SMTP_HOST="smtp.titan.email"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="Dwell Hub <noreply@dwellhub.in>"
