{
  "name": "@pwa-apart/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npx prisma generate",
    "vercel-build": "sh scripts/vercel-build.sh",
    "railway-build": "npx prisma@5.22.0 generate && npx prisma@5.22.0 migrate deploy && tsc",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "generate": "npx prisma@5.22.0 generate",
    "db:migrate": "npx prisma@5.22.0 migrate dev",
    "db:deploy": "npx prisma@5.22.0 migrate deploy",
    "db:deploy:safe": "sh scripts/prisma-deploy-safe.sh",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma@5.22.0 studio",
    "db:generate": "npx prisma@5.22.0 generate",
    "lint": "eslint src/",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "prisma": "5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
