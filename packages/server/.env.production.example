# === Production Environment ===
# Switch to PostgreSQL for production
DATABASE_URL="postgresql://user:password@host:5432/aparteasedb?sslmode=require"
# Optional but recommended for Prisma migrations on hosted providers (direct/non-pooled connection)
DIRECT_URL="postgresql://user:password@db.host:5432/aparteasedb?sslmode=require"

# Auth
JWT_SECRET="generate-a-strong-secret-here"
JWT_REFRESH_SECRET="generate-another-strong-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="production"

# PhonePe (configured via Admin UI Settings page, these are fallback only)
PHONEPE_MERCHANT_ID=""
PHONEPE_SALT_KEY=""
PHONEPE_SALT_INDEX="1"
PHONEPE_ENV="PRODUCTION"
PHONEPE_BASE_URL="https://api.phonepe.com/apis/hermes"
PHONEPE_REDIRECT_URL="https://your-frontend.vercel.app/billing?payment=done"
PHONEPE_CALLBACK_URL="https://your-backend.vercel.app/api/payments/phonepe/callback"

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
CLIENT_URL="https://your-frontend.vercel.app"
