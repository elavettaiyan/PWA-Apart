---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Resilynk — Apartment Society Management Software',
  description = 'Apartment management software for Indian housing societies. Manage billing, maintenance payments, complaints, expenses, documents, and reports in one place.',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = 'https://resilynk.com';
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Keywords (supplementary signal) -->
    <meta
      name="keywords"
      content="apartment management software, society management app, RWA management system, housing society management, apartment billing software India, flat management system, maintenance bill generation, society expense tracking, apartment complaint management, online maintenance payment, housing society accounting, gated community management app"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Resilynk apartment society management software" />
    <meta property="og:site_name" content="Resilynk" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter  -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Resilynk apartment society management software" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Resilynk",
        "url": siteUrl,
        "description": description
      },
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Resilynk",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, Android",
        "description": description,
        "url": siteUrl,
        "image": ogImageUrl
      }
    ])} />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>
