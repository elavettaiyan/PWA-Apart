---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Dwell Hub | Community Management for Apartments, Villas & Gated Communities',
  description = 'Transforming complex community logistics into a serene digital environment. Manage billing, payments, complaints, expenses, bylaws, and reports for apartments, villas, and gated communities.',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = 'https://dwellhub.in';
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Keywords (supplementary signal) -->
    <meta
      name="keywords"
      content="apartment management software, society management app, RWA management system, housing society management, apartment billing software India, flat management system, maintenance bill generation, society expense tracking, apartment complaint management, online maintenance payment, housing society accounting, gated community management app, villa community management, villa society app, gated township management, dwell hub"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Dwell Hub — apartment society management, made clearer" />
    <meta property="og:site_name" content="Dwell Hub" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter  -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Dwell Hub — apartment society management, made clearer" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#05213a" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Dwell Hub",
        "url": siteUrl,
        "description": description
      },
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Dwell Hub",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, Android",
        "description": description,
        "url": siteUrl,
        "image": ogImageUrl
      }
    ])} />

    <!-- Lottie Player -->
    <script src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>

    <style is:global>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .editorial-shadow {
        box-shadow: 0 32px 64px -12px rgba(25, 28, 27, 0.06);
      }
      body { font-family: 'Inter', sans-serif; }
      h1, h2, h3, .font-manrope { font-family: 'Manrope', sans-serif; }
    </style>
  </head>
  <body class="bg-surface text-on-surface selection:bg-secondary-container selection:text-on-secondary-container antialiased">
    <slot />
  </body>
</html>
