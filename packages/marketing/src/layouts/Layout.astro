---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string;
  noindex?: boolean;
  /** Optional extra JSON-LD structured-data objects to inject (e.g. FAQPage, BreadcrumbList). */
  structuredData?: Record<string, unknown>[];
}

const DEFAULT_KEYWORDS = [
  // Primary head terms
  'apartment management software India',
  'society management app',
  'visitor management software apartment',
  'maintenance billing software apartment',
  // Core category terms
  'apartment management software',
  'housing society management software',
  'RWA management software',
  'gated community management app',
  'villa community management software',
  'apartment society management system',
  'flat maintenance management software',
  // Feature / intent terms
  'society maintenance billing software',
  'maintenance bill generation software',
  'online maintenance payment app',
  'society accounting software India',
  'apartment complaint management software',
  'visitor and gate management system',
  'society expense tracking software',
  'defaulter tracking apartment society',
  'AGM reports society software',
  'resident self-service portal',
  // Brand
  'Dwell Hub',
].join(', ');

const {
  title = 'Dwell Hub | Apartment & Society Management Software in India',
  description = 'Dwell Hub is apartment and society management software for India — maintenance billing, online payments, visitor & gate management, complaints, expenses, bylaws, and AGM-ready reports for apartments, villas, and gated communities.',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  keywords = DEFAULT_KEYWORDS,
  noindex = false,
  structuredData = [],
} = Astro.props;

const siteUrl = 'https://dwellhub.in';
const ogImageUrl = `${siteUrl}${ogImage}`;

const baseStructuredData: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Dwell Hub',
    url: siteUrl,
    logo: `${siteUrl}/apple-touch-icon.png`,
    description,
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'support@dwellhub.in',
      contactType: 'customer support',
      areaServed: 'IN',
      availableLanguage: ['en'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Dwell Hub',
    url: siteUrl,
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Dwell Hub',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web, Android, iOS',
    description,
    url: siteUrl,
    image: ogImageUrl,
    offers: {
      '@type': 'Offer',
      price: '20',
      priceCurrency: 'INR',
      description: '₹20 per flat per month. 30-day free trial, up to 50 flats.',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      ratingCount: '120',
    },
  },
];

const allStructuredData = [...baseStructuredData, ...structuredData];
---


<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta name="googlebot" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />

    <!-- Keywords (supplementary signal) -->
    <meta name="keywords" content={keywords} />

    <!-- Geo / locale targeting -->
    <meta name="geo.region" content="IN" />
    <meta name="geo.placename" content="India" />
    <meta name="author" content="Dwell Hub" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Dwell Hub — apartment society management, made clearer" />
    <meta property="og:site_name" content="Dwell Hub" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter  -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Dwell Hub — apartment society management, made clearer" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#05213a" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(allStructuredData)} />


    <!-- Lottie Player -->
    <script src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>

    <style is:global>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .editorial-shadow {
        box-shadow: 0 32px 64px -12px rgba(25, 28, 27, 0.06);
      }
      body { font-family: 'Inter', sans-serif; }
      h1, h2, h3, .font-manrope { font-family: 'Manrope', sans-serif; }
    </style>
  </head>
  <body class="bg-surface text-on-surface selection:bg-secondary-container selection:text-on-secondary-container antialiased">
    <slot />
  </body>
</html>
