---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const title = 'Resilynk — Apartment Society Management Software for Indian Housing Societies';
const description = 'Manage apartment society billing, maintenance payments, complaints, expenses, documents, and reports in one place with Resilynk.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Features />
    <FAQ />
  </main>
  <Footer />
</Layout>
