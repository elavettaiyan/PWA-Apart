---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Roles from '../components/Roles.astro';
import Transparency from '../components/Transparency.astro';
import Comparison from '../components/Comparison.astro';
import MobileApps from '../components/MobileApps.astro';
import BlogSection from '../components/BlogSection.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const title = 'Apartment & Society Management Software in India | Dwell Hub';
const description = 'Dwell Hub is apartment and society management software for India — maintenance billing, online payments, visitor & gate management, complaints, expenses, bylaws, and AGM-ready reports for apartments, villas, and gated communities. 30-day free trial, then ₹20/flat/month.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Features />
    <Comparison />
    <Roles />
    <Transparency />
    <BlogSection />
    <MobileApps />
    <FAQ />
  </main>
  <Footer />
</Layout>
