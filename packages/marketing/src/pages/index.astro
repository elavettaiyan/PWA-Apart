---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Roles from '../components/Roles.astro';
import Transparency from '../components/Transparency.astro';
import MobileApps from '../components/MobileApps.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const title = 'Apartment & Society Management Software in India | Dwell Hub';
const description = 'Dwell Hub helps small and medium apartment communities digitize billing, resident records, visitor tracking, complaints, and reports. Built for societies still using paper, WhatsApp, or Excel.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Features />
    <Roles />
    <Transparency />
    <MobileApps />
    <FAQ />
  </main>
  <Footer />
</Layout>
