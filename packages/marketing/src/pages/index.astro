---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const title = 'Dwell Hub | Apartment Society Management, Made Clearer';
const description = 'Transforming complex community logistics into a serene digital environment. Manage billing, payments, complaints, expenses, bylaws, and reports with Dwell Hub.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Features />
    <FAQ />
  </main>
  <Footer />
</Layout>
