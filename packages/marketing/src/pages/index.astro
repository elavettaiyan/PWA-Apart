---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Roles from '../components/Roles.astro';
import Transparency from '../components/Transparency.astro';
import Comparison from '../components/Comparison.astro';
import MobileApps from '../components/MobileApps.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const title = 'Dwell Hub | Community Management for Apartments, Villas & Gated Communities';
const description = 'Manage billing, collections, complaints, expenses, and reports for your apartment society, villa community, or gated township. Built for committees that value transparency and residents who expect self-service.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Features />
    <Comparison />
    <Roles />
    <Transparency />
    <MobileApps />
    <FAQ />
  </main>
  <Footer />
</Layout>
