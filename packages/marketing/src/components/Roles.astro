---
const roles = [
  {
    icon: 'apartment',
    tone: 'secondary',
    title: 'Replace paper & WhatsApp',
    bullets: ['Move from notebooks to digital records', 'Stop chasing dues on WhatsApp', 'One source of truth for the committee', 'Residents self-serve their own data'],
  },
  {
    icon: 'groups',
    tone: 'primary',
    title: '20 to 100+ flats',
    bullets: ['Designed for small & medium societies', 'Scales to larger communities too', 'Committee and resident-ready', 'Multi-society support built in'],
  },
  {
    icon: 'rocket_launch',
    tone: 'tertiary',
    title: 'Start in minutes',
    bullets: ['Import flats from Excel', 'No training needed for residents', 'Add features as you grow', '₹20/flat/month — no surprises'],
  },
];
---

<section id="benefits" class="py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 text-center max-w-2xl mx-auto">
      <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3 font-label">Why Dwell Hub</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-3 font-headline">Digitize your society in 3 steps.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {roles.map((role) => (
        <div class:list={[
          'p-6 rounded-2xl border transition-all duration-300 hover:translate-y-[-2px] hover:shadow-lg group',
          role.tone === 'primary' && 'bg-white border-outline-variant/55 hover:border-primary/20',
          role.tone === 'secondary' && 'bg-secondary-container/25 border-secondary-fixed-dim/55 hover:border-secondary/25',
          role.tone === 'tertiary' && 'bg-tertiary-fixed/25 border-tertiary-fixed-dim/55 hover:border-tertiary/25',
        ]}>
          <div class="flex items-center gap-3 mb-4">
            <div class:list={[
              'w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors',
              role.tone === 'primary' && 'bg-primary-fixed/35 group-hover:bg-primary-fixed/55',
              role.tone === 'secondary' && 'bg-white/70 group-hover:bg-white',
              role.tone === 'tertiary' && 'bg-white/75 group-hover:bg-white',
            ]}>
              <span class:list={[
                'material-symbols-outlined text-2xl',
                role.tone === 'primary' && 'text-primary',
                role.tone === 'secondary' && 'text-secondary',
                role.tone === 'tertiary' && 'text-tertiary',
              ]}>{role.icon}</span>
            </div>
            <h3 class="text-base font-bold text-primary font-headline">{role.title}</h3>
          </div>
          <ul class="space-y-2">
            {role.bullets.map((bullet) => (
              <li class="flex items-start gap-2 text-sm text-on-surface-variant font-body">
                <span class:list={[
                  'material-symbols-outlined text-[14px] mt-0.5 flex-shrink-0',
                  role.tone === 'primary' && 'text-primary',
                  role.tone === 'secondary' && 'text-secondary',
                  role.tone === 'tertiary' && 'text-tertiary',
                ]}>check</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
