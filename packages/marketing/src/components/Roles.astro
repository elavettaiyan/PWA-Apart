---
const roles = [
  {
    icon: 'apartment',
    title: 'Replace paper & WhatsApp',
    bullets: ['Move from notebooks to digital records', 'Stop chasing dues on WhatsApp', 'One source of truth for the committee', 'Residents self-serve their own data'],
  },
  {
    icon: 'groups',
    title: '20 to 100+ flats',
    bullets: ['Designed for small & medium societies', 'Scales to larger communities too', 'Committee and resident-ready', 'Multi-society support built in'],
  },
  {
    icon: 'rocket_launch',
    title: 'Start in minutes',
    bullets: ['Import flats from Excel', 'No training needed for residents', 'Add features as you grow', '₹20/flat/month — no surprises'],
  },
];
---

<section id="benefits" class="py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 text-center max-w-2xl mx-auto">
      <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3 font-label">Why Dwell Hub</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-3 font-headline">Digitize your society in 3 steps.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {roles.map((role) => (
        <div class="bg-white p-6 rounded-2xl border border-slate-100 transition-all duration-300 hover:translate-y-[-2px] hover:shadow-lg hover:border-accent/20 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-accent/8 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-accent/12 transition-colors">
              <span class="material-symbols-outlined text-accent text-2xl">{role.icon}</span>
            </div>
            <h3 class="text-base font-bold text-primary font-headline">{role.title}</h3>
          </div>
          <ul class="space-y-2">
            {role.bullets.map((bullet) => (
              <li class="flex items-start gap-2 text-sm text-on-surface-variant font-body">
                <span class="material-symbols-outlined text-[14px] text-emerald-500 mt-0.5 flex-shrink-0">check</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
