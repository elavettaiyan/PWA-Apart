---
const appUrl = 'https://app.dwellhub.in';

const navItems = [
  { href: '/#top', label: 'Home', id: 'top' },
  { href: '/#features', label: 'Features', id: 'features' },
  { href: '/#benefits', label: 'Benefits', id: 'benefits' },
  { href: '/pricing', label: 'Pricing', id: 'pricing' },
  { href: '/blog', label: 'Blog', id: 'blog' },
  { href: '/#faq', label: 'FAQ', id: 'faq' },
  { href: '/#contact', label: 'Contact', id: 'contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-2xl border-b border-outline-variant/60 transition-all duration-300">
  <div class="flex items-center justify-between px-6 py-3 max-w-7xl mx-auto">
    <a href="/" class="inline-flex items-center gap-3.5 text-on-surface font-headline">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-surface-container-low ring-1 ring-outline-variant/60 shadow-sm">
        <img src="/favicon.svg" alt="Dwell Hub logo" class="h-9 w-9 rounded-xl" />
      </span>
      <span class="text-[1.15rem] font-black leading-none tracking-[-0.03em]">Dwell Hub</span>
    </a>

    <div class="hidden md:flex items-center gap-1 bg-surface-container-low/90 rounded-full px-2 py-1.5">
      {navItems.map((item) => (
        <a
          class="marketing-nav-link font-headline text-[13px] tracking-wide font-medium text-on-surface-variant px-4 py-1.5 rounded-full hover:text-primary hover:bg-white transition-all duration-200"
          href={item.href}
          data-section={item.id}
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={`${appUrl}/login`} class="hidden sm:inline font-headline text-[13px] tracking-wide font-medium text-on-surface-variant hover:text-primary transition-colors">
        Login
      </a>
      <a href={`${appUrl}/register`} class="bg-primary text-white px-5 py-2.5 rounded-full font-headline text-[13px] tracking-wide font-semibold hover:bg-primary-container hover:shadow-lg hover:shadow-primary/20 transition-all">
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  const activeClasses = ['text-primary', 'bg-white', 'shadow-sm'];
  const inactiveClasses = ['text-on-surface-variant'];

  const links = Array.from(document.querySelectorAll('.marketing-nav-link'));
  const sections = links
    .map((link) => document.getElementById(link.dataset.section || ''))
    .filter(Boolean);

  function setActiveSection(activeId) {
    links.forEach((link) => {
      const isActive = link.dataset.section === activeId;
      link.classList.toggle(activeClasses[0], isActive);
      link.classList.toggle(activeClasses[1], isActive);
      link.classList.toggle(inactiveClasses[0], !isActive);
      link.classList.toggle(inactiveClasses[1], !isActive);
    });
  }

  function updateFromHash() {
    const hash = window.location.hash.replace('#', '');
    if (hash && sections.some((section) => section.id === hash)) {
      setActiveSection(hash);
      return true;
    }

    return false;
  }

  if (!updateFromHash()) {
    setActiveSection('');
  }

  const observer = new IntersectionObserver(
    (entries) => {
      const visibleEntries = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

      if (visibleEntries.length > 0) {
        setActiveSection(visibleEntries[0].target.id);
      } else if (!updateFromHash()) {
        setActiveSection('');
      }
    },
    {
      rootMargin: '-30% 0px -55% 0px',
      threshold: [0.15, 0.35, 0.6],
    },
  );

  sections.forEach((section) => observer.observe(section));

  window.addEventListener('hashchange', updateFromHash);
</script>
