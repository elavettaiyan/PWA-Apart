---
const appUrl = 'https://app.dwellhub.in';
---

<nav class="fixed top-0 w-full z-50 bg-[#f9faf7]/80 backdrop-blur-xl transition-all duration-300">
  <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
    <a href="/" class="text-2xl font-bold tracking-tighter text-primary font-headline">
      Dwell Hub
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a class="font-headline text-sm tracking-wide font-medium text-primary border-b-2 border-primary pb-1 transition-all duration-300 hover:opacity-70" href="#features">Features</a>
      <a class="font-headline text-sm tracking-wide font-medium text-slate-600 hover:text-primary transition-all duration-300" href="#pricing">Pricing</a>
      <a class="font-headline text-sm tracking-wide font-medium text-slate-600 hover:text-primary transition-all duration-300" href="#faq">Support</a>
    </div>

    <div class="flex items-center gap-4">
      <a href={`${appUrl}/login`} class="font-headline text-sm tracking-wide font-medium text-slate-600 hover:text-primary transition-colors">
        Login
      </a>
      <a href={`${appUrl}/register`} class="bg-primary text-on-primary px-6 py-2.5 rounded-xl font-headline text-sm tracking-wide font-medium hover:opacity-90 transition-opacity">
        Get Started
      </a>
    </div>
  </div>
</nav>
