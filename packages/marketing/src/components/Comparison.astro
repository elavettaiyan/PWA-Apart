---
const appUrl = 'https://app.dwellhub.in';

const rows = [
  {
    label: 'Platform fee',
    icon: 'payments',
    others: '₹3–15 /flat/month base fee',
    perFlat: 5,
    ours: '₹20 /flat/month',
    oursNote: 'All core workflows included',
  },
  {
    label: 'Payment gateway',
    icon: 'account_balance',
    others: '1.5–2 % per txn (≈₹30 on ₹1,500 bill)',
    perFlat: 30,
    ours: '0 %',
    oursNote: 'UPI is free in India',
  },
  {
    label: 'Setup & onboarding',
    icon: 'handshake',
    others: '₹10,000+ one-time (≈₹17/flat/mo over 12 mo)',
    perFlat: 17,
    ours: 'Free',
    oursNote: 'Self-serve setup in minutes',
  },
  {
    label: 'Feature modules',
    icon: 'extension',
    others: '₹2–5 /flat extra per module (≈₹25 /flat total)',
    perFlat: 25,
    ours: 'Everything included',
    oursNote: 'Billing, complaints, gate management, reports, and more',
  },
  {
    label: 'SMS & notifications',
    icon: 'notifications',
    others: '₹500+ /month (≈₹10/flat for 50 flats)',
    perFlat: 10,
    ours: 'Free',
    oursNote: 'Push notifications & email',
  },
  {
    label: 'Contract lock-in',
    icon: 'lock',
    others: '12 months minimum',
    ours: 'None',
    oursNote: 'Cancel anytime',
  },
];

const totals = [
  { flats: 50, others: '~₹4,350', ours: '₹1,000' },
];

const summaryTotals = [
  {
    label: 'Per flat',
    others: '~₹87/month',
    ours: '₹20/month',
  },
  {
    label: '50-flat society',
    others: '~₹4,350/month',
    ours: '₹1,000/month',
  },
  {
    label: '100-flat society',
    others: '~₹8,700/month',
    ours: '₹2,000/month',
  },
];
---

<section id="pricing" class="bg-surface-container-low py-24 px-8">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-12 max-w-3xl">
      <p class="text-xs font-bold tracking-widest uppercase text-primary mb-4 font-label">Clear Monthly Pricing</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-6 font-headline leading-tight">
        Manage your 50-flat community for just ₹1,000/month.
      </h2>
      <p class="text-on-surface-variant font-body leading-relaxed">
        Start with the number your committee actually needs. Dwell Hub keeps billing simple: one transparent monthly price, core workflows included, and no setup surprises.
      </p>
    </div>

    <!-- Intro -->
    <div class="mb-12 max-w-3xl">
      <h3 class="text-xl font-bold text-primary font-headline mb-3">Why total cost stays predictable</h3>
      <p class="text-on-surface-variant font-body leading-relaxed">
        Most apps start with a low sticker price but pile on charges for modules, SMS packs, payment processing, and mandatory onboarding — making the real monthly cost much higher. Dwell Hub folds everything your committee needs into one transparent number.
      </p>
    </div>

    <!-- Mobile Comparison Cards -->
    <div class="sm:hidden space-y-4">
      {rows.map((row) => (
        <div class="bg-surface-container-lowest rounded-2xl overflow-hidden editorial-shadow">
          <div class="p-5 border-b border-primary/5 flex items-start gap-3">
            <div class="w-9 h-9 bg-primary/5 rounded-lg flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">{row.icon}</span>
            </div>
            <div>
              <p class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Cost Item</p>
              <h4 class="mt-1 font-semibold text-base text-primary font-headline leading-snug">{row.label}</h4>
            </div>
          </div>

          <div class="p-5 bg-surface-container-low/50 border-b border-primary/5 space-y-1">
            <p class="text-[10px] font-bold tracking-widest uppercase text-on-surface-variant font-label">Typical Apps</p>
            <p class="text-sm text-on-surface-variant font-body leading-relaxed">{row.others}</p>
          </div>

          <div class="p-5 bg-primary/[0.06] flex items-start gap-3">
            <span class="material-symbols-outlined text-emerald-600 text-lg flex-shrink-0 mt-0.5">check_circle</span>
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase text-on-surface-variant font-label">Dwell Hub</p>
              <p class="mt-1 text-base font-bold text-primary font-headline leading-snug">{row.ours}</p>
              <p class="mt-1 text-xs text-on-surface-variant font-body leading-relaxed">{row.oursNote}</p>
            </div>
          </div>
        </div>
      ))}

      <div class="bg-surface-container-lowest rounded-2xl overflow-hidden editorial-shadow border border-primary/10">
        <div class="p-5 bg-primary text-on-primary flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 32 32" fill="none" class="flex-shrink-0">
            <rect width="32" height="32" rx="8" fill="rgba(255,255,255,0.15)"/>
            <path d="M22 26V10a2 2 0 00-2-2h-8a2 2 0 00-2 2v16m14 0h1.5m-1.5 0h-4m-10 0H8.5m1.5 0h4M13 13h1m-1 3h1m4-3h1m-1 3h1m-4 10v-4a1 1 0 011-1h2a1 1 0 011 1v4m-4 0h4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <span class="text-sm font-bold tracking-tighter font-headline block">Dwell Hub</span>
            <span class="text-[10px] font-bold tracking-widest uppercase opacity-70">Save 4×</span>
          </div>
        </div>

        {summaryTotals.map((total) => (
          <div class="border-t border-primary/5">
            <div class="p-5 bg-surface-container-low/30">
              <p class="text-[10px] font-bold tracking-widest uppercase text-on-surface-variant font-label">Summary</p>
              <p class="mt-1 font-bold text-primary font-headline text-base">{total.label}</p>
            </div>
            <div class="grid grid-cols-2">
              <div class="p-5 bg-error-container/30">
                <p class="text-[10px] font-bold tracking-widest uppercase text-on-error-container/70 font-label">Typical Apps</p>
                <p class="mt-1 text-base font-bold text-error font-headline line-through decoration-error/40">{total.others}</p>
              </div>
              <div class="p-5 bg-primary text-on-primary">
                <p class="text-[10px] font-bold tracking-widest uppercase text-on-primary/70 font-label">Dwell Hub</p>
                <p class="mt-1 text-lg font-extrabold text-on-primary font-headline">{total.ours}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Desktop Comparison Table -->
    <div class="hidden sm:block bg-surface-container-lowest rounded-2xl overflow-hidden editorial-shadow relative">

      <!-- Column Headers -->
      <div class="grid sm:grid-cols-[2fr_1.5fr_1.5fr] border-b border-primary/5">
        <div class="p-6 lg:p-8">
          <span class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Cost Item</span>
        </div>
        <div class="p-6 lg:p-8 bg-surface-container-low/50">
          <span class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Typical Apps</span>
        </div>
        <div class="p-6 lg:p-8 bg-primary text-on-primary flex items-center gap-3 relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 32 32" fill="none" class="flex-shrink-0">
            <rect width="32" height="32" rx="8" fill="rgba(255,255,255,0.15)"/>
            <path d="M22 26V10a2 2 0 00-2-2h-8a2 2 0 00-2 2v16m14 0h1.5m-1.5 0h-4m-10 0H8.5m1.5 0h4M13 13h1m-1 3h1m4-3h1m-1 3h1m-4 10v-4a1 1 0 011-1h2a1 1 0 011 1v4m-4 0h4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <span class="text-sm font-bold tracking-tighter font-headline block">Dwell Hub</span>
            <span class="text-[10px] font-bold tracking-widest uppercase opacity-70">Save 4×</span>
          </div>
        </div>
      </div>

      <!-- Rows -->
      {rows.map((row) => (
        <div class="grid sm:grid-cols-[2fr_1.5fr_1.5fr] border-b border-primary/5">
          <div class="p-6 lg:p-8 flex items-start gap-4">
            <div class="w-9 h-9 bg-primary/5 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-primary text-xl">{row.icon}</span>
            </div>
            <span class="font-semibold text-sm text-primary font-headline">{row.label}</span>
          </div>
          <div class="p-6 lg:p-8 bg-surface-container-low/50 flex items-start">
            <span class="text-sm text-on-surface-variant font-body">{row.others}</span>
          </div>
          <div class="p-6 lg:p-8 bg-primary/[0.06] flex items-start gap-3">
            <span class="material-symbols-outlined text-emerald-600 text-lg flex-shrink-0 mt-0.5">check_circle</span>
            <div>
              <span class="text-sm font-bold text-primary font-headline block">{row.ours}</span>
              <span class="text-xs text-on-surface-variant font-body">{row.oursNote}</span>
            </div>
          </div>
        </div>
      ))}

      <!-- Total Rows -->
      <div class="border-t-2 border-primary/15">
        {summaryTotals.map((total) => (
          <div class="grid sm:grid-cols-[2fr_1.5fr_1.5fr] border-b border-primary/5 last:border-b-0">
            <div class="p-6 lg:p-8 flex items-center gap-4 bg-surface-container-low/30">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary text-xl">calculate</span>
              </div>
              <span class="font-bold text-sm text-primary font-headline">{total.label}</span>
            </div>
            <div class="p-6 lg:p-8 bg-error-container/30 flex items-center">
              <span class="text-lg font-bold text-error font-headline line-through decoration-error/40">{total.others}</span>
            </div>
            <div class="p-6 lg:p-8 bg-primary flex items-center">
              <span class="text-xl font-extrabold text-on-primary font-headline">{total.ours}</span>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Pricing Summary + CTA -->
    <div class="mt-16 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-3 bg-surface-container-lowest px-5 py-3 rounded-xl">
            <span class="material-symbols-outlined text-primary text-xl">home</span>
            <div>
              <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest font-bold">Free Tier</p>
              <p class="text-sm font-semibold text-primary font-headline">Up to 5 flats — ₹0 forever</p>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-surface-container-lowest px-5 py-3 rounded-xl">
            <span class="material-symbols-outlined text-primary text-xl">apartment</span>
            <div>
              <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest font-bold">Premium</p>
              <p class="text-sm font-semibold text-primary font-headline">₹20 × all flats/month</p>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-surface-container-lowest px-5 py-3 rounded-xl">
            <span class="material-symbols-outlined text-primary text-xl">task_alt</span>
            <div>
              <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest font-bold">Included</p>
              <p class="text-sm font-semibold text-primary font-headline">Billing, complaints, gate, reports</p>
            </div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-5 flex lg:justify-end">
        <a href={`${appUrl}/register`} class="bg-primary text-on-primary px-8 py-4 rounded-xl font-bold tracking-wide hover:opacity-90 transition-opacity editorial-shadow text-center w-full sm:w-auto">
          Start free, scale when ready
        </a>
      </div>
    </div>

  </div>
</section>
