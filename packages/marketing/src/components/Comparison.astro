---
const appUrl = 'https://app.dwellhub.in';

const rows = [
  {
    label: 'Platform fee',
    icon: 'payments',
    others: '₹3–15 /flat/month base fee',
    perFlat: 5,
    ours: '₹20 /flat/month',
    oursNote: 'All core workflows included',
  },
  {
    label: 'Payment gateway',
    icon: 'account_balance',
    others: '1.5–2 % per txn (≈₹30 on ₹1,500 bill)',
    perFlat: 30,
    ours: '0 %',
    oursNote: 'UPI is free in India',
  },
  {
    label: 'Setup & onboarding',
    icon: 'handshake',
    others: '₹10,000+ one-time (≈₹17/flat/mo over 12 mo)',
    perFlat: 17,
    ours: 'Free',
    oursNote: 'Self-serve setup in minutes',
  },
  {
    label: 'Feature modules',
    icon: 'extension',
    others: '₹2–5 /flat extra per module (≈₹25 /flat total)',
    perFlat: 25,
    ours: 'Everything included',
    oursNote: 'Billing, complaints, gate management, reports, and more',
  },
  {
    label: 'SMS & notifications',
    icon: 'notifications',
    others: '₹500+ /month (≈₹10/flat for 50 flats)',
    perFlat: 10,
    ours: 'Free',
    oursNote: 'Push notifications & email',
  },
  {
    label: 'Contract lock-in',
    icon: 'lock',
    others: '12 months minimum',
    ours: 'None',
    oursNote: 'Cancel anytime',
  },
];

const totals = [
  { flats: 50, others: '~₹4,350', ours: '₹1,000' },
];

const summaryTotals = [
  {
    label: 'Per flat',
    others: '~₹87/month',
    ours: '₹20/month',
  },
  {
    label: '50-flat society',
    others: '~₹4,350/month',
    ours: '₹1,000/month',
  },
  {
    label: '100-flat society',
    others: '~₹8,700/month',
    ours: '₹2,000/month',
  },
];
---

<section id="pricing" class="pt-28 pb-16 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="mb-12 text-center max-w-2xl mx-auto">
      <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3 font-label">Simple Pricing</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-3 font-headline leading-tight">
        Transparent pricing. No hidden fees.
      </h2>
      <p class="text-on-surface-variant font-body text-sm">One price per flat, all features included. See how Dwell Hub compares.</p>
    </div>

    <!-- Pricing highlight cards -->
    <div class="mb-12 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
      <div class="rounded-2xl bg-secondary-container/30 border border-secondary-fixed-dim/55 p-6 text-center">
        <div class="w-10 h-10 bg-white/75 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-secondary text-xl">hourglass_top</span>
        </div>
        <p class="text-lg font-extrabold text-primary font-headline">30 days free</p>
        <p class="mt-1 text-xs text-on-surface-variant font-body">Full access, no card needed</p>
      </div>
      <div class="rounded-2xl bg-primary p-6 text-center shadow-lg shadow-primary/15">
        <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-white text-xl">payments</span>
        </div>
        <p class="text-lg font-extrabold text-white font-headline">₹20 / flat / mo</p>
        <p class="mt-1 text-xs text-primary-fixed font-body">Everything included</p>
      </div>
      <div class="rounded-2xl bg-tertiary-fixed/30 border border-tertiary-fixed-dim/55 p-6 text-center">
        <div class="w-10 h-10 bg-white/75 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-tertiary text-xl">lock_open</span>
        </div>
        <p class="text-lg font-extrabold text-primary font-headline">No lock-in</p>
        <p class="mt-1 text-xs text-on-surface-variant font-body">Cancel anytime</p>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="rounded-2xl border border-outline-variant overflow-hidden bg-white">

      <!-- Table Header -->
      <div class="grid grid-cols-[1fr_1fr_1fr] border-b border-outline-variant bg-surface-container-low">
        <div class="p-4 lg:p-5">
          <span class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Cost Item</span>
        </div>
        <div class="p-4 lg:p-5 border-l border-outline-variant">
          <span class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Typical Apps</span>
        </div>
        <div class="p-4 lg:p-5 border-l border-outline-variant bg-primary-fixed/25">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold tracking-widest uppercase text-accent font-label">Dwell Hub</span>
            <span class="text-[9px] font-bold tracking-widest uppercase bg-error-container text-on-error-container px-2 py-0.5 rounded-full">Save 4×</span>
          </div>
        </div>
      </div>

      <!-- Rows -->
      {rows.map((row, i) => (
        <div class:list={["grid grid-cols-[1fr_1fr_1fr]", i < rows.length - 1 && "border-b border-outline-variant/55"]}>
          <div class="p-4 lg:p-5 flex items-center gap-3">
            <div class="w-8 h-8 bg-secondary-container/45 rounded-lg flex items-center justify-center flex-shrink-0 hidden sm:flex">
              <span class="material-symbols-outlined text-secondary text-lg">{row.icon}</span>
            </div>
            <span class="text-sm font-semibold text-primary font-headline">{row.label}</span>
          </div>
          <div class="p-4 lg:p-5 border-l border-outline-variant/55 flex items-center">
            <span class="text-sm text-on-surface-variant font-body">{row.others}</span>
          </div>
          <div class="p-4 lg:p-5 border-l border-outline-variant/55 bg-primary-fixed/15 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-base flex-shrink-0">check_circle</span>
            <div>
              <span class="text-sm font-bold text-primary font-headline">{row.ours}</span>
              <span class="block text-[11px] text-on-surface-variant font-body">{row.oursNote}</span>
            </div>
          </div>
        </div>
      ))}

      <!-- Totals -->
      <div class="border-t-2 border-outline-variant">
        {summaryTotals.map((total, i) => (
          <div class:list={["grid grid-cols-[1fr_1fr_1fr]", i < summaryTotals.length - 1 && "border-b border-outline-variant/55"]}>
            <div class="p-4 lg:p-5 flex items-center bg-surface-container-low">
              <span class="text-sm font-bold text-primary font-headline">{total.label}</span>
            </div>
            <div class="p-4 lg:p-5 border-l border-outline-variant/55 flex items-center bg-error-container/70">
              <span class="text-base font-bold text-on-error-container font-headline line-through decoration-on-error-container/40">{total.others}</span>
            </div>
            <div class="p-4 lg:p-5 border-l border-outline-variant/55 flex items-center bg-primary">
              <span class="text-lg font-extrabold text-white font-headline">{total.ours}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a href={`${appUrl}/register`} class="inline-block bg-primary text-white px-10 py-4 rounded-full font-bold text-base tracking-wide hover:bg-primary-container hover:shadow-lg hover:shadow-primary/20 transition-all">
        Start your 30-day free trial
      </a>
      <p class="mt-3 text-xs text-on-surface-variant font-body">No credit card required · Cancel anytime</p>
    </div>

  </div>
</section>
