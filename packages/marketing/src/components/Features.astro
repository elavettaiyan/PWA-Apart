---
const features = [
  { icon: 'receipt_long', title: 'Billing & Invoicing', description: 'Automated maintenance cycles with clear, editorial-style PDF statements for every unit.' },
  { icon: 'payments', title: 'Online Payments', description: 'Integrated gateway for UPI, cards, and net banking with instant reconciliation.' },
  { icon: 'assignment_late', title: 'Complaint Tracking', description: 'Ticket-based resolution system with real-time status updates for residents and staff.' },
  { icon: 'account_balance_wallet', title: 'Expense Management', description: 'Full ledger transparency for society spending, including vendor payouts and petty cash.' },
  { icon: 'gavel', title: 'Bylaws & Documents', description: 'A digital archive for rules, meeting minutes, and legal certificates accessible 24/7.' },
  { icon: 'analytics', title: 'Reports & Analytics', description: 'Visual data representations of society health, from occupancy rates to collection trends.' },
];
---

<section id="features" class="bg-surface-container-low py-24 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20 text-center lg:text-left max-w-2xl">
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-4 font-headline uppercase">The Society Toolkit</h2>
      <p class="text-on-surface-variant font-body">A curated suite of essential tools designed to streamline community operations without visual clutter.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="bg-surface-container-lowest p-10 rounded-xl transition-all duration-300 hover:translate-y-[-4px]">
          <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-primary text-3xl">{feature.icon}</span>
          </div>
          <h3 class="text-xl font-bold text-primary mb-3 font-headline">{feature.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-body">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
