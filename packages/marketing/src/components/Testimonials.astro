---
const testimonials = [
  {
    name: 'Rajesh Kumar',
    role: 'President, Green Valley Apartments',
    location: 'Bangalore',
    text: 'Resilynk transformed how we manage our 120-flat society. Billing that used to take 3 days now happens in one click. Residents love the online payment option.',
    avatar: 'RK',
    color: 'bg-blue-100 text-blue-700',
  },
  {
    name: 'Priya Sharma',
    role: 'Secretary, Sunrise Heights RWA',
    location: 'Mumbai',
    text: 'We moved from messy spreadsheets to Resilynk and the difference is night and day. Complaint tracking alone saved us hours of WhatsApp back-and-forth every week.',
    avatar: 'PS',
    color: 'bg-purple-100 text-purple-700',
  },
  {
    name: 'Arun Nair',
    role: 'Treasurer, Palm Garden Society',
    location: 'Chennai',
    text: 'The expense tracking and reports feature gives our committee complete transparency. Our residents trust the management more since we started using Resilynk.',
    avatar: 'AN',
    color: 'bg-emerald-100 text-emerald-700',
  },
];
---

<section id="testimonials" class="py-20 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        Loved by committees
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tight">
        Trusted by housing societies
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        See how apartment associations across India are simplifying their management with Resilynk.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-shadow duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-gray-700 leading-relaxed mb-6">"{t.text}"</p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm ${t.color}`}>
              {t.avatar}
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">{t.name}</div>
              <div class="text-xs text-gray-500">{t.role} · {t.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
