---
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.resilynk.mobile&pcampaignid=web_share';
const appStoreUrl = 'https://apps.apple.com/in/app/dwell-hub/id6764814825';
---

<section id="mobile-apps" class="py-24 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20 text-center lg:text-left max-w-2xl">
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-4 font-headline">Available Everywhere</h2>
      <p class="text-on-surface-variant font-body">Access Dwell Hub from your phone, tablet, or desktop. Choose the option that works best for you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Android App -->
      <div class="bg-surface-container-lowest p-10 rounded-xl transition-all duration-300 hover:translate-y-[-4px] flex flex-col">
        <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center mb-6">
          <!-- Android logo -->
          <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.523 15.341a.85.85 0 0 1-.851-.851.85.85 0 0 1 .851-.851.85.85 0 0 1 .851.851.85.85 0 0 1-.851.851m-11.046 0a.85.85 0 0 1-.851-.851.85.85 0 0 1 .851-.851.85.85 0 0 1 .851.851.85.85 0 0 1-.851.851m11.386-5.974 1.67-2.893a.347.347 0 0 0-.127-.474.347.347 0 0 0-.474.127l-1.692 2.93A10.29 10.29 0 0 0 12 8.384a10.29 10.29 0 0 0-5.24 1.673L5.068 7.127a.347.347 0 0 0-.474-.127.347.347 0 0 0-.127.474l1.67 2.893C3.529 11.77 1.999 14.47 2 17.46h20c.001-2.99-1.529-5.69-4.137-7.093"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-primary mb-3 font-headline">Android App</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed font-body mb-8 flex-1">
          Get the full native experience on your Android phone. Fast, reliable, and built for on-the-go society management with push notifications.
        </p>
        <a
          href={playStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary text-on-primary px-6 py-3.5 rounded-xl font-headline text-sm tracking-wide font-medium hover:opacity-90 transition-opacity self-start"
        >
          <!-- Google Play icon -->
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92ZM14.852 13.06l2.29 2.29-11.678 6.57 9.388-8.86ZM20.166 10.834l-2.57 1.445-2.537-2.28 2.536-2.278 2.57 1.445a1.25 1.25 0 0 1 0 1.668ZM5.464 2.08l11.678 6.57-2.29 2.29L5.464 2.08Z"/>
          </svg>
          Get it on Google Play
        </a>
      </div>

      <!-- iOS App -->
      <div class="bg-surface-container-lowest p-10 rounded-xl transition-all duration-300 hover:translate-y-[-4px] flex flex-col">
        <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center mb-6">
          <!-- Apple logo -->
          <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-primary mb-3 font-headline">iOS App</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed font-body mb-8 flex-1">
          Get the full native experience on iPhone and iPad. Available now on the App Store with push notifications and seamless society management.
        </p>
        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary text-on-primary px-6 py-3.5 rounded-xl font-headline text-sm tracking-wide font-medium hover:opacity-90 transition-opacity self-start"
        >
          <!-- Apple icon -->
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download on App Store
        </a>
      </div>


    </div>
  </div>
</section>
