---
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.resilynk.mobile&pcampaignid=web_share';
const appStoreUrl = 'https://apps.apple.com/in/app/dwell-hub/id6764814825';
const desktopScreenshot = '/app-showcase/desktop-dashboard.png';
const mobileScreenshot = '/app-showcase/mobile-dashboard.png';
---

<section id="mobile-apps" class="py-24 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 max-w-3xl">
      <p class="text-xs font-bold tracking-widest uppercase text-primary mb-4 font-label">Product Experience</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-4 font-headline leading-tight">See Dwell Hub across desktop and mobile.</h2>
      <p class="text-on-surface-variant font-body leading-relaxed">Your committee can manage operations from a large-screen dashboard, while residents and staff stay productive on the go with the mobile app. The same core workflows stay clear on every screen.</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-[1.1fr_1fr] gap-10 items-center">
      <div class="bg-primary text-on-primary rounded-[2rem] p-8 sm:p-10 editorial-shadow relative overflow-hidden">
        <div class="absolute -top-20 right-0 w-64 h-64 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -bottom-24 left-0 w-72 h-72 rounded-full bg-tertiary-fixed/20 blur-3xl"></div>

        <div class="relative z-10">
          <div class="flex flex-wrap gap-3 mb-6">
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">Desktop dashboard</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">Android app</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">iPhone app</span>
          </div>

          <h3 class="text-3xl font-extrabold font-headline mb-4 leading-tight">One product system for admins, residents, and on-site teams.</h3>
          <p class="text-on-primary-container font-body leading-relaxed mb-8 max-w-xl">Large-screen control for billing and approvals. Fast mobile views for society updates, collections, complaints, and day-to-day tasks. No cut-down experience between devices.</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            <div class="rounded-2xl bg-white/10 p-5 border border-white/10">
              <p class="text-xs font-bold tracking-widest uppercase text-on-primary/70 font-label mb-2">Desktop</p>
              <p class="text-lg font-bold font-headline">Committee control center</p>
              <p class="mt-2 text-sm text-on-primary-container font-body">Billing, resident management, financial summaries, and society-wide reporting.</p>
            </div>
            <div class="rounded-2xl bg-white/10 p-5 border border-white/10">
              <p class="text-xs font-bold tracking-widest uppercase text-on-primary/70 font-label mb-2">Mobile</p>
              <p class="text-lg font-bold font-headline">Actionable on the move</p>
              <p class="mt-2 text-sm text-on-primary-container font-body">Owners, admins, and staff can keep up with updates, dues, entries, and approvals anywhere.</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-4">
            <a
              href={playStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 bg-surface text-primary px-6 py-3.5 rounded-xl font-headline text-sm tracking-wide font-medium hover:opacity-90 transition-opacity"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92ZM14.852 13.06l2.29 2.29-11.678 6.57 9.388-8.86ZM20.166 10.834l-2.57 1.445-2.537-2.28 2.536-2.278 2.57 1.445a1.25 1.25 0 0 1 0 1.668ZM5.464 2.08l11.678 6.57-2.29 2.29L5.464 2.08Z"/>
              </svg>
              Google Play
            </a>
            <a
              href={appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 border border-white/15 bg-white/10 text-on-primary px-6 py-3.5 rounded-xl font-headline text-sm tracking-wide font-medium hover:bg-white/15 transition-colors"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              App Store
            </a>
          </div>
        </div>
      </div>

      <div class="relative min-h-[34rem] lg:min-h-[42rem]">
        <div class="absolute inset-x-0 top-0 rounded-[2rem] border border-primary/10 bg-surface-container-lowest p-4 editorial-shadow">
          <div class="flex items-center justify-between px-3 pb-3">
            <div>
              <p class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label">Desktop Experience</p>
              <p class="text-sm font-semibold text-primary font-headline">Billing and society overview on one screen</p>
            </div>
            <span class="hidden sm:inline-flex rounded-full bg-primary/5 px-3 py-1 text-xs font-semibold text-primary">Web App</span>
          </div>
          <img src={desktopScreenshot} alt="Dwell Hub desktop dashboard with society billing and resident overview" class="w-full rounded-[1.5rem] border border-primary/10 object-cover" loading="lazy" />
        </div>

        <div class="absolute bottom-0 right-4 sm:right-8 w-44 sm:w-56 rounded-[2rem] border border-primary/10 bg-surface-container-lowest p-2 editorial-shadow">
          <div class="px-3 pt-3 pb-2">
            <p class="text-[10px] font-bold tracking-widest uppercase text-on-surface-variant font-label">Mobile Experience</p>
            <p class="mt-1 text-sm font-semibold text-primary font-headline">Fast at the gate and on the go</p>
          </div>
          <div class="rounded-[1.5rem] border border-primary/10 bg-surface overflow-hidden">
            <img src={mobileScreenshot} alt="Dwell Hub mobile app with finance and occupancy overview" class="w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
