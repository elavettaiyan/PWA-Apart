---
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.resilynk.mobile&hl=en-US';
const appStoreUrl = 'https://apps.apple.com/in/app/dwell-hub/id6764814825';
---

<section id="mobile-apps" class="py-16 px-6 bg-indigo-50/40">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 text-center max-w-2xl mx-auto">
      <p class="text-xs font-bold tracking-widest uppercase text-[#4f46e5] mb-3 font-label">Download Dwell Hub</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-3 font-headline leading-tight">One app for admins, residents &amp; staff.</h2>
      <p class="text-on-surface-variant font-body text-sm">Android, iPhone, or browser — same society, same data, same access.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8 max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center">
        <div class="w-11 h-11 bg-[#4f46e5]/8 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-[#4f46e5] text-2xl">android</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">Android</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-1">Google Play</p>
      </div>
      <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center">
        <div class="w-11 h-11 bg-[#4f46e5]/8 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-[#4f46e5] text-2xl">phone_iphone</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">iPhone</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-1">App Store</p>
      </div>
      <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center">
        <div class="w-11 h-11 bg-[#4f46e5]/8 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-[#4f46e5] text-2xl">language</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">Web App</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-1">Any browser</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
      <a
        href={playStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group rounded-2xl bg-white border border-slate-100 p-5 hover:border-[#4f46e5]/20 hover:shadow-md transition-all text-center"
      >
        <div class="w-12 h-12 rounded-xl bg-[#4f46e5]/8 flex items-center justify-center mx-auto mb-3 group-hover:bg-[#4f46e5]/12 transition-colors">
          <svg class="w-6 h-6 text-[#4f46e5]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92ZM14.852 13.06l2.29 2.29-11.678 6.57 9.388-8.86ZM20.166 10.834l-2.57 1.445-2.537-2.28 2.536-2.278 2.57 1.445a1.25 1.25 0 0 1 0 1.668ZM5.464 2.08l11.678 6.57-2.29 2.29L5.464 2.08Z"/>
          </svg>
        </div>
        <p class="text-base font-bold text-primary font-headline mb-1">Get it on Google Play</p>
        <p class="text-xs text-on-surface-variant font-body">Android app for all society roles</p>
        <span class="inline-flex items-center gap-1.5 mt-3 text-sm font-semibold text-[#4f46e5]">
          Open <span class="material-symbols-outlined text-sm">north_east</span>
        </span>
      </a>

      <a
        href={appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group rounded-2xl bg-white border border-slate-100 p-5 hover:border-[#4f46e5]/20 hover:shadow-md transition-all text-center"
      >
        <div class="w-12 h-12 rounded-xl bg-[#4f46e5]/8 flex items-center justify-center mx-auto mb-3 group-hover:bg-[#4f46e5]/12 transition-colors">
          <svg class="w-6 h-6 text-[#4f46e5]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </div>
        <p class="text-base font-bold text-primary font-headline mb-1">Download on App Store</p>
        <p class="text-xs text-on-surface-variant font-body">iPhone &amp; iPad</p>
        <span class="inline-flex items-center gap-1.5 mt-3 text-sm font-semibold text-[#4f46e5]">
          Open <span class="material-symbols-outlined text-sm">north_east</span>
        </span>
      </a>
    </div>
  </div>
</section>
