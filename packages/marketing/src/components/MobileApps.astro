---
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.resilynk.mobile&hl=en-US';
const appStoreUrl = 'https://apps.apple.com/in/app/dwell-hub/id6764814825';
---

<section id="mobile-apps" class="py-24 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 max-w-3xl">
      <p class="text-xs font-bold tracking-widest uppercase text-primary mb-4 font-label">Download Dwell Hub</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-4 font-headline leading-tight">Choose your device and start using Dwell Hub.</h2>
      <p class="text-on-surface-variant font-body leading-relaxed">Install the mobile app for residents, admins, and on-site teams, or open Dwell Hub instantly in your browser for full desktop access.</p>
    </div>

    <div class="w-full">
      <div class="bg-primary text-on-primary rounded-[2rem] p-8 sm:p-10 editorial-shadow relative overflow-hidden">
        <div class="absolute -top-16 right-0 w-64 h-64 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -bottom-24 left-0 w-72 h-72 rounded-full bg-tertiary-fixed/20 blur-3xl"></div>

        <div class="relative z-10">
          <div class="flex flex-wrap gap-3 mb-6">
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">Android</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">iPhone</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold tracking-widest uppercase font-label">Web</span>
          </div>

          <h3 class="text-3xl font-extrabold font-headline mb-4 leading-tight">Download the app with clear access on every platform.</h3>
          <p class="text-on-primary-container font-body leading-relaxed mb-8 max-w-2xl">Use Dwell Hub on Android or iPhone for daily society operations, or open the web app for full desktop control. Downloads and access links are listed below with no extra steps.</p>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <a
              href={playStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-[1.5rem] bg-surface text-primary p-6 border border-primary/10 hover:translate-y-[-2px] transition-transform"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-bold tracking-widest uppercase text-on-surface-variant font-label mb-2">Android App</p>
                  <p class="text-2xl font-extrabold font-headline mb-2">Get it on Google Play</p>
                  <p class="text-sm text-on-surface-variant font-body leading-relaxed">Install the Dwell Hub mobile app for admins, residents, guards, and staff.</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary/5 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92ZM14.852 13.06l2.29 2.29-11.678 6.57 9.388-8.86ZM20.166 10.834l-2.57 1.445-2.537-2.28 2.536-2.278 2.57 1.445a1.25 1.25 0 0 1 0 1.668ZM5.464 2.08l11.678 6.57-2.29 2.29L5.464 2.08Z"/>
                  </svg>
                </div>
              </div>
              <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary">
                Open Google Play
                <span class="material-symbols-outlined text-base">north_east</span>
              </div>
            </a>

            <a
              href={appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-[1.5rem] border border-white/15 bg-white/10 text-on-primary p-6 hover:bg-white/15 transition-colors"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-bold tracking-widest uppercase text-on-primary/70 font-label mb-2">iPhone App</p>
                  <p class="text-2xl font-extrabold font-headline mb-2">Download on the App Store</p>
                  <p class="text-sm text-on-primary-container font-body leading-relaxed">Use Dwell Hub on iPhone and iPad with the same society access and updates.</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-on-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                  </svg>
                </div>
              </div>
              <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-on-primary">
                Open App Store
                <span class="material-symbols-outlined text-base">north_east</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
