---
const appUrl = 'https://app.dwellhub.in';
const mobileScreenshot = '/app-showcase/mobile-dashboard.png';
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.resilynk.mobile&hl=en-US';
const appStoreUrl = 'https://apps.apple.com/in/app/dwell-hub/id6764814825';
---

<!-- Hero -->
<section id="top" class="relative px-6 pt-28 pb-16 lg:pt-32 lg:pb-20 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-bl from-primary-fixed/40 via-secondary-container/30 to-transparent rounded-full blur-3xl opacity-80 pointer-events-none"></div>

  <!-- Centered Content -->
  <div class="relative z-10 max-w-3xl mx-auto text-center">
    <span class="inline-flex items-center gap-2 text-accent bg-accent/5 border border-accent/10 px-4 py-1.5 rounded-full text-[11px] font-bold tracking-widest uppercase mb-6 font-label">
      <span class="material-symbols-outlined text-sm">phone_iphone</span>
      Mobile-first apartment management
    </span>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-primary tracking-tight leading-[1.1] mb-5 font-headline">
      Manage your apartment<br class="hidden sm:block"/> society in one app
    </h1>

    <p class="text-lg text-on-surface-variant font-body mb-8 max-w-xl mx-auto">
      Billing, residents, visitors, complaints &amp; reports — digitize everything from day one.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
      <a href={`${appUrl}/register`} class="bg-primary text-white px-8 py-3.5 rounded-full font-bold tracking-wide hover:bg-primary-container hover:shadow-lg hover:shadow-primary/20 transition-all text-center text-sm">
        Start Free Trial
      </a>
      <a href="#features" class="bg-secondary-container text-secondary px-7 py-3.5 rounded-full font-bold tracking-wide hover:bg-secondary-fixed-dim hover:text-on-secondary-fixed transition-colors text-center text-sm">
        Explore Features
      </a>
      <a href="/pricing" class="border border-outline-variant bg-surface-container-lowest px-7 py-3.5 rounded-full font-bold tracking-wide text-on-surface hover:border-tertiary-fixed-dim hover:text-tertiary transition-colors text-center text-sm">
        See Pricing
      </a>
    </div>

    <div class="flex flex-wrap gap-3 justify-center text-[11px] font-bold tracking-wide uppercase text-on-surface-variant font-label">
      <span class="inline-flex items-center gap-1.5 bg-primary-fixed/30 text-primary rounded-full px-3.5 py-1.5 border border-primary-fixed-dim/60"><span class="material-symbols-outlined text-sm">verified</span>30-day free trial</span>
      <span class="inline-flex items-center gap-1.5 bg-secondary-container/50 rounded-full px-3.5 py-1.5 border border-secondary-fixed-dim/70"><span class="material-symbols-outlined text-sm text-secondary">apartment</span>20–100+ flats</span>
      <span class="inline-flex items-center gap-1.5 bg-tertiary-fixed/50 rounded-full px-3.5 py-1.5 border border-tertiary-fixed-dim/70"><span class="material-symbols-outlined text-sm text-tertiary">phone_iphone</span>Android, iOS &amp; Web</span>
    </div>
  </div>
</section>

<!-- Stats strip -->
<section class="px-6 pb-12">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href={playStoreUrl} target="_blank" rel="noopener noreferrer" class="group rounded-2xl border border-outline-variant/50 bg-surface-container-lowest p-4 hover:border-primary/20 hover:shadow-md transition-all text-center">
        <div class="w-10 h-10 rounded-xl bg-primary-fixed/30 flex items-center justify-center mx-auto mb-2 group-hover:bg-primary-fixed/45 transition-colors">
          <span class="material-symbols-outlined text-primary text-xl">android</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">Android</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-0.5">Google Play</p>
      </a>
      <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="group rounded-2xl border border-outline-variant/50 bg-surface-container-lowest p-4 hover:border-secondary/20 hover:shadow-md transition-all text-center">
        <div class="w-10 h-10 rounded-xl bg-secondary-container/55 flex items-center justify-center mx-auto mb-2 group-hover:bg-secondary-container/80 transition-colors">
          <span class="material-symbols-outlined text-secondary text-xl">phone_iphone</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">iOS App</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-0.5">App Store</p>
      </a>
      <a href="#features" class="group rounded-2xl border border-outline-variant/50 bg-surface-container-lowest p-4 hover:border-tertiary/20 hover:shadow-md transition-all text-center">
        <div class="w-10 h-10 rounded-xl bg-tertiary-fixed/55 flex items-center justify-center mx-auto mb-2 group-hover:bg-tertiary-fixed/75 transition-colors">
          <span class="material-symbols-outlined text-tertiary text-xl">receipt_long</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">Billing</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-0.5">Dues & payments</p>
      </a>
      <a href="#features" class="group rounded-2xl border border-outline-variant/50 bg-surface-container-lowest p-4 hover:border-secondary/20 hover:shadow-md transition-all text-center">
        <div class="w-10 h-10 rounded-xl bg-secondary-container/55 flex items-center justify-center mx-auto mb-2 group-hover:bg-secondary-container/80 transition-colors">
          <span class="material-symbols-outlined text-secondary text-xl">shield</span>
        </div>
        <p class="text-sm font-bold text-primary font-headline">Gate & Visitors</p>
        <p class="text-[11px] text-on-surface-variant font-body mt-0.5">Entry tracking</p>
      </a>
    </div>
  </div>
</section>
