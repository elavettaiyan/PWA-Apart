---
const appUrl = 'https://app.dwellhub.in';
---

<section class="relative px-8 py-20 lg:py-32 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
  <div class="lg:col-span-6 z-10">
    <span class="inline-block text-on-tertiary-container bg-tertiary-container/10 px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase mb-6 font-label">The Modern Curator</span>

    <h1 class="text-5xl lg:text-7xl font-extrabold text-primary tracking-tight leading-[1.1] mb-8 font-headline">
      Apartment society management, <span class="text-on-tertiary-container italic">made clearer.</span>
    </h1>

    <p class="text-lg text-on-surface-variant max-w-xl mb-10 leading-relaxed font-body">
      Transforming complex community logistics into a serene digital environment. Built on institutional trust and editorial clarity for the modern resident.
    </p>

    <div class="flex flex-wrap gap-4">
      <a href={`${appUrl}/register`} class="bg-primary text-on-primary px-8 py-4 rounded-xl font-bold tracking-wide hover:opacity-90 transition-opacity editorial-shadow">
        Schedule a Demo
      </a>
      <a href="#features" class="bg-secondary-container text-on-secondary-container px-8 py-4 rounded-xl font-bold tracking-wide hover:opacity-90 transition-opacity">
        Explore Platform
      </a>
    </div>
  </div>

  <div class="lg:col-span-6 relative">
    <div class="absolute -top-10 -right-10 w-64 h-64 bg-tertiary/5 rounded-full blur-3xl"></div>
    <div class="relative rounded-2xl overflow-hidden aspect-[4/5] lg:aspect-square editorial-shadow">
      <img
        class="w-full h-full object-cover"
        alt="Modern minimalist architectural building with clean glass lines"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuB69Fbrfoi0Oo8Yecu4CBIGPy-zfjPLZOx0Lj5TWzYuxEmTHppuzEJKnnciuTFQYvSfJkEnwAbkiHARS1xaS1ML6egYsGepOYZiEi1xYn-W7XoHzFIXOru5bDuXZS2kQTXFXri8Nj8GNZDjbu8A66ZIYLy5TkYrvuXTkj14uWZ_AV8aAz9HhR2bbeHzKFP-abZKtSzj6zgEQcYya6_moTzOgv28L2xdFsrYm7e_u_UaFhgXyMAqnknaJXhGmqQv5ZdXMeWk0_cNDWw"
      />
      <div class="absolute bottom-0 left-0 right-0 p-8 bg-gradient-to-t from-primary/80 to-transparent">
        <p class="text-white/80 font-label text-xs tracking-widest uppercase">Signature Project</p>
        <p class="text-white text-xl font-headline font-bold">The Obsidian Heights, 2026</p>
      </div>
    </div>
  </div>
</section>
