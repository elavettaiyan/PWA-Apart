---
const faqs = [
  {
    question: 'How much does it cost?',
    answer: '₹20 per flat per month. A 50-flat society pays ₹1,000/month. All core features included — no extra module charges.',
  },
  {
    question: 'Is there a free trial?',
    answer: 'Yes — 30 days, no payment required. Full access to all features with up to 50 flats.',
  },
  {
    question: 'How secure is our data?',
    answer: '256-bit encryption, ISO-certified data centers, siloed per society, and strict access controls.',
  },
  {
    question: 'Can we import existing flat data?',
    answer: 'Yes. Upload your Excel file and get started in minutes.',
  },
  {
    question: 'What payment methods do residents get?',
    answer: 'UPI, credit/debit cards, and net banking via PhonePe. Payments reconcile instantly.',
  },
  {
    question: 'Which devices are supported?',
    answer: 'Android app, iOS app, and web browser. Works on mobile and desktop.',
  },
  {
    question: 'What reports can we generate?',
    answer: 'P&L statements, collection reports, defaulter lists, and expense summaries. All filterable by date range and ready for AGM.',
  },
  {
    question: 'How are committee roles handled?',
    answer: '9 distinct roles including Secretary, Treasurer, Admin, and Committee Members — each with appropriate permissions.',
  },
  {
    question: 'Is there a lock-in contract?',
    answer: 'No. Cancel anytime. No annual contracts or exit fees.',
  },
  {
    question: 'How do I get started?',
    answer: 'Click "Get Started", add your society details, import flats, and you\'re live. Takes under 10 minutes.',
  },
];
---

<section id="faq" class="py-16 px-6 max-w-7xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    <div class="lg:col-span-4">
      <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3 font-label">FAQ</p>
      <h2 class="text-4xl font-extrabold text-primary tracking-tight mb-6 font-headline">Frequently Asked</h2>

      <div class="space-y-3">
        <div class="bg-secondary-container/35 rounded-2xl p-5 border border-secondary-fixed-dim/55">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-2 font-label">Support Desk</p>
          <a href="mailto:support@dwellhub.in" class="text-primary font-headline font-bold text-sm break-all hover:text-accent transition-colors">
            support@dwellhub.in
          </a>
          <p class="text-xs text-on-surface-variant font-body mt-1.5">
            Product help &amp; billing questions
          </p>
        </div>

        <div class="bg-tertiary-fixed/35 rounded-2xl p-5 border border-tertiary-fixed-dim/55">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-2 font-label">Marketing Desk</p>
          <a href="mailto:marketing@dwellhub.in" class="text-primary font-headline font-bold text-sm break-all hover:text-accent transition-colors">
            marketing@dwellhub.in
          </a>
          <p class="text-xs text-on-surface-variant font-body mt-1.5">
            Partnerships &amp; demo requests
          </p>
        </div>
      </div>
    </div>

    <div class="lg:col-span-8 space-y-3">
      {faqs.map((faq) => (
        <details class="group bg-white rounded-2xl p-5 border border-outline-variant/55 open:border-secondary/25 open:bg-secondary-container/12 open:shadow-sm transition-all">
          <summary class="flex justify-between items-center font-bold text-primary cursor-pointer list-none [&::-webkit-details-marker]:hidden text-sm">
            <span>{faq.question}</span>
            <span class="material-symbols-outlined text-accent group-open:rotate-180 transition-transform">expand_more</span>
          </summary>
          <div class="mt-4 text-on-surface-variant leading-relaxed text-sm font-body">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FAQPage Structured Data (rich results) -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
})} />
