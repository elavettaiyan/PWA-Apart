---
const faqs = [
  {
    question: 'What is Resilynk?',
    answer: 'Resilynk is a complete apartment society management platform built for Indian housing societies. It helps RWA committees manage billing, collect maintenance payments online, track complaints, record expenses, share bylaws, and generate financial reports — all from one dashboard.',
  },
  {
    question: 'Is Resilynk really free?',
    answer: 'Yes, Resilynk is completely free to use for all housing societies. There are no hidden charges, no premium tiers, and no credit card required. Register your society and start using all features immediately.',
  },
  {
    question: 'How do I register my society?',
    answer: 'Click the "Register Your Society" button, fill in your society details (name, address, admin info), and you\'re ready to go in under 2 minutes. As the admin, you can then add blocks, flats, and invite residents.',
  },
  {
    question: 'Can residents pay maintenance online?',
    answer: 'Yes! Resilynk integrates with PhonePe for UPI-based maintenance payments. Residents receive their bills and can pay instantly from their phone. Payment confirmation is immediate and receipts are generated automatically.',
  },
  {
    question: 'Is my society\'s data secure?',
    answer: 'Absolutely. All data is encrypted in transit and at rest. Each society\'s data is completely isolated — no one from another society can ever access your information. We use industry-standard security practices including JWT authentication and role-based access control.',
  },
  {
    question: 'Can I use Resilynk on my phone?',
    answer: 'Yes, Resilynk works as a Progressive Web App (PWA) on any browser and also has a dedicated Android app. Add it to your home screen for an app-like experience. All features work seamlessly on mobile devices.',
  },
];
---

<section id="faq" class="py-20 md:py-32 bg-gray-50">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        Got questions?
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 tracking-tight">
        Frequently asked questions
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Everything you need to know about Resilynk. Can't find an answer? Email us at support@resilynk.com.
      </p>
    </div>

    <!-- FAQ items -->
    <div class="space-y-4">
      {faqs.map((faq, i) => (
        <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden" open={i === 0}>
          <summary class="flex items-center justify-between cursor-pointer p-6 text-left font-semibold text-gray-900 hover:text-primary-600 transition-colors [&::-webkit-details-marker]:hidden list-none">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed -mt-2">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
