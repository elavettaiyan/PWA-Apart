---
const appUrl = 'https://app.dwellhub.in';
---

<!-- Final CTA -->
<section class="px-8 pb-32">
  <div class="max-w-7xl mx-auto relative overflow-hidden bg-primary rounded-2xl p-12 lg:p-24 text-center">
    <!-- Abstract Background Patterns -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-container opacity-50 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-tertiary opacity-30 rounded-full blur-[80px]"></div>

    <div class="relative z-10 max-w-2xl mx-auto">
      <h2 class="text-4xl lg:text-5xl font-extrabold text-on-primary mb-8 font-headline leading-tight">
        Ready to elevate your community living?
      </h2>
      <p class="text-on-primary-container text-lg mb-10 font-body">
        Set up your society in minutes. Billing, complaints, reports — everything your committee needs, in one place.
      </p>
      <a href={`${appUrl}/register`} class="inline-block bg-surface text-primary px-10 py-5 rounded-xl font-bold text-lg tracking-wide hover:opacity-90 transition-opacity editorial-shadow">
        Get Started Today
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="w-full border-t border-[#05213a]/5 bg-[#f3f4f2]">
  <div class="flex flex-col gap-10 px-12 py-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10">
      <div class="flex flex-col gap-4">
        <div class="text-lg font-black text-primary font-headline">Dwell Hub</div>
        <p class="text-slate-500 font-label text-xs uppercase tracking-widest font-semibold">&copy; {new Date().getFullYear()} Dwell Hub. The Modern Curator of Community.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:min-w-[30rem]">
        <a href="mailto:support@dwellhub.in" class="bg-surface-container-lowest rounded-xl px-5 py-4 border border-primary/5 hover:border-primary/15 transition-colors">
          <p class="text-[11px] font-label uppercase tracking-widest font-semibold text-slate-500 mb-2">Support</p>
          <p class="text-primary font-headline font-bold">support@dwellhub.in</p>
        </a>
        <a href="mailto:marketing@dwellhub.in" class="bg-surface-container-lowest rounded-xl px-5 py-4 border border-primary/5 hover:border-primary/15 transition-colors">
          <p class="text-[11px] font-label uppercase tracking-widest font-semibold text-slate-500 mb-2">Marketing</p>
          <p class="text-primary font-headline font-bold">marketing@dwellhub.in</p>
        </a>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-wrap gap-8">
        <a class="font-label text-xs uppercase tracking-widest font-semibold text-slate-500 hover:text-tertiary transition-colors" href="/privacy">Privacy Policy</a>
        <a class="font-label text-xs uppercase tracking-widest font-semibold text-slate-500 hover:text-tertiary transition-colors" href="/terms">Terms of Service</a>
        <a class="font-label text-xs uppercase tracking-widest font-semibold text-slate-500 hover:text-tertiary transition-colors" href="/refund-policy">Refund Policy</a>
      </div>

      <p class="text-xs text-slate-500 font-body text-center md:text-right">
        Reach the right team directly for product support or growth conversations.
      </p>
    </div>
  </div>
</footer>
