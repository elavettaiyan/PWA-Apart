---
const appUrl = 'https://app.resilynk.com';
---

<!-- CTA Section -->
<section class="py-20 md:py-28 bg-gradient-to-br from-primary-600 via-primary-700 to-indigo-800 relative overflow-hidden">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.05%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')] opacity-50"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight">
      Ready to simplify your society management?
    </h2>
    <p class="mt-4 text-lg text-primary-100 max-w-2xl mx-auto">
      Join hundreds of housing societies across India who trust Resilynk. Free forever — register in under 2 minutes.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`${appUrl}/register`}
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-primary-700 font-semibold text-lg px-8 py-4 rounded-2xl shadow-xl hover:shadow-2xl transition-all hover:-translate-y-0.5"
      >
        Register Your Society
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href={`${appUrl}/login`}
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-white border-2 border-white/30 hover:border-white/60 font-semibold text-lg px-8 py-4 rounded-2xl transition-all"
      >
        Login to Dashboard
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 text-gray-400 py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-primary-600 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <span class="text-xl font-bold text-white">Resilynk</span>
        </div>
        <p class="text-gray-400 max-w-md leading-relaxed">
          Your Apartment, Connected. A complete apartment society management platform built for Indian housing societies — billing, payments, complaints, expenses, and more.
        </p>
      </div>

      <!-- Product links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Product</h3>
        <ul class="space-y-3">
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#testimonials" class="hover:text-white transition-colors">Testimonials</a></li>
          <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href={`${appUrl}/register`} class="hover:text-white transition-colors">Register</a></li>
          <li><a href={`${appUrl}/login`} class="hover:text-white transition-colors">Login</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:support@resilynk.com" class="hover:text-white transition-colors">support@resilynk.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm">&copy; {new Date().getFullYear()} Resilynk. All rights reserved.</p>
      <p class="text-sm">Made with ❤️ for Indian housing societies</p>
    </div>
  </div>
</footer>
