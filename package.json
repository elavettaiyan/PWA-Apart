{
  "name": "pwa-apart",
  "version": "1.0.0",
  "private": true,
  "description": "Apartment Management Progressive Web App",
  "workspaces": [
    "packages/server",
    "packages/client",
    "packages/marketing"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd packages/server && npm run dev",
    "dev:client": "cd packages/client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm --prefix packages/server run generate && npm --prefix packages/server run build",
    "build:client": "npm --prefix packages/client run build",
    "db:migrate": "npm --prefix packages/server run db:migrate",
    "db:seed": "npm --prefix packages/server run db:seed",
    "db:studio": "npm --prefix packages/server run db:studio",
    "lint": "concurrently \"npm --prefix packages/server run lint\" \"npm --prefix packages/client run lint\"",
    "postinstall": "npx prisma@5.22.0 generate --schema=packages/server/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
